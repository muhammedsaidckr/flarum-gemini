{
  "extends": "flarum-tsconfig",
  "include": [
      "src/**/*",
      "../vendor/flarum/core/js/dist-typings/@types/**/*",
      "@types/**/*"
  ],
  "compilerOptions": {
    "declarationDir": "./dist-typings",
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "flarum/*": ["../vendor/flarum/core/js/dist-typings/*"]
    },
    "types": ["mithril", "jquery"]
  }
}
